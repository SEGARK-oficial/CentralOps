# ============================================================================
# CentralOps - Environment Variables
# ============================================================================
# Copie este arquivo para .env e ajuste os valores conforme necessario.
#   cp .env.example .env
# ============================================================================

# ── Docker / Compose ─────────────────────────────────────────────────────────
IMAGE_NAME=centralops
HTTP_PORT=3000
HTTPS_PORT=3443

# Volumes nomeados — sobrevivem a `docker compose down/up/restart/--build`.
# São apagados apenas com `docker compose down -v` ou `docker volume rm`.
APP_DATA_VOLUME=centralops-db
APP_SSL_VOLUME=centralops-ssl
POSTGRES_DATA_VOLUME=centralops-postgres
REDIS_DATA_VOLUME=centralops-redis
COLLECTOR_LOGS_VOLUME=centralops-collector-logs

# ── Aplicacao ────────────────────────────────────────────────────────────────
# Chave mestra de criptografia (min 32 caracteres). Se nao informada, sera
# gerada automaticamente e persistida em /app/data/app_master_key.
# Gere com: openssl rand -hex 32
# APP_MASTER_KEY=

# APP_ENV=production exige SESSION_SECURE_COOKIE=true (validator).
# Para dev local sem TLS, use APP_ENV=development.
APP_ENV=production
# Obrigatorio em producao com HTTPS (Fase 4 hardening).
SESSION_SECURE_COOKIE=true
APP_COMPANY_NAME=Sua Empresa
APP_COMPANY_PORTAL_NAME=Portal de Login

# ── Secrets backend / Criptografia (Fase 4 hardening) ────────────────────────
# Backend de criptografia das credenciais de integração:
#   local_fernet       — default (AES local derivado de APP_MASTER_KEY).
#   kms_wrapped_fernet — envelope encryption via KMS (recomendado em produção;
#                        exige um KmsBackend real ou o stub local de dev/test).
# SECRETS_BACKEND=local_fernet
# TTL (segundos) do cache in-memory de DEKs desempacotadas. 0 desabilita o cache.
# KMS_DEK_CACHE_TTL_SECONDS=60
#
# Provedor de KMS (só vale com SECRETS_BACKEND=kms_wrapped_fernet). Separa o
# MECANISMO (envelope) do PROVEDOR — novos KMS plugam sem novo SECRETS_BACKEND.
#   local_stub     — dev/test (master key em arquivo; NÃO usar em produção).
#   vault_transit  — HashiCorp Vault Transit (recomendado prod). O Transit é
#                    open-source: funciona em Vault Community Edition (CE) —
#                    NÃO exige HCP/Enterprise. (instale: pip install -r
#                    requirements-vault.txt). Migração de dados existentes:
#                    scripts/reencrypt_secrets.py (enc:: → kmsenc::, legacy_fallback
#                    decifra os antigos durante a transição — zero-downtime).
# KMS_PROVIDER=local_stub
#
# Vault Transit (quando KMS_PROVIDER=vault_transit):
# VAULT_ADDR=https://vault.interno:8200
# VAULT_TRANSIT_KEY_NAME=centralops        # vault write -f transit/keys/centralops
# VAULT_TRANSIT_MOUNT=transit
# VAULT_AUTH_METHOD=approle                 # "token" ou "approle" (recomendado)
# VAULT_TOKEN=                              # se auth=token
# VAULT_ROLE_ID=                            # se auth=approle
# VAULT_SECRET_ID=                          # se auth=approle
# VAULT_APPROLE_MOUNT=approle
# VAULT_NAMESPACE=                          # só Vault Enterprise (no-op em CE)
# VAULT_VERIFY_TLS=true                     # false só p/ dev com cert self-signed

# ── Banco de Dados (Postgres) ────────────────────────────────────────────────
# O compose sobe um Postgres 16-alpine como BD primario com volume nomeado
# (centralops-postgres). DATABASE_URL e montado a partir destas vars
# automaticamente — basta trocar a senha em producao.
#
# Senha do Postgres — OBRIGATORIA. Sem valor o compose recusa subir.
# Gere com: openssl rand -base64 24
POSTGRES_USER=centralops
POSTGRES_PASSWORD=
POSTGRES_DB=centralops
# Porta exposta ao host (so usada se voce descomentar `ports:` no service
# postgres do compose, util pra conectar com psql/DBeaver de fora).
# POSTGRES_PORT=5432

# DATABASE_URL — derivada das vars acima por padrao. Sobrescreva apenas se:
#  (a) usa um Postgres externo/managed (RDS, Neon, etc); ou
#  (b) quer voltar a SQLite (dev sem Postgres):
#      DATABASE_URL=sqlite:////app/data/sophos.db
# DATABASE_URL=postgresql+psycopg2://centralops:senha@postgres:5432/centralops

# ── Frontend (build-time) ────────────────────────────────────────────────────
VITE_BACKEND_URL=/api

# ── Nginx / HTTPS (serviço `frontend`) ───────────────────────────────────────
# o frontend agora é um container separado (nginx + SPA) que expõe
# as portas e proxia /api -> API. Estas variaveis vao para o serviço `frontend`.
# ⚠️ No orquestrador/reverse-proxy: aponte o dominio/porta para o serviço
# `frontend` (nao o `centralops`). HTTP_PORT/HTTPS_PORT (topo do arquivo) sao publicados por ele.
# Nome do servidor Nginx (use o dominio em producao, ex: centralops.exemplo.com)
NGINX_SERVER_NAME=_
ENABLE_HTTPS=1
# Upstream da API que o frontend proxia em /api (nome do serviço:porta).
API_UPSTREAM=centralops:8000
# Caminhos para certificados proprios (opcional - gera self-signed se ausente)
# NGINX_SSL_CERT_PATH=/certs/tls.crt
# NGINX_SSL_KEY_PATH=/certs/tls.key
# NGINX_SSL_CERT_VALID_DAYS=365

# ── Sessao / Cookies ────────────────────────────────────────────────────────
# com o split, a API nao deriva mais isto do ENABLE_HTTPS (que
# agora vive no frontend). Default da API = 1 (cookie Secure, TLS na borda).
# Para rodar a stack em HTTP puro (dev), setar SESSION_SECURE_COOKIE=0 AQUI e
# ENABLE_HTTPS=0 no frontend.
# SESSION_SECURE_COOKIE=1
# SESSION_COOKIE_NAME=sophos_session
# SESSION_TTL_HOURS=12
# SESSION_SAMESITE=lax

# ── CORS ─────────────────────────────────────────────────────────────────────
# Lista de origens separadas por virgula. Em producao, defina o dominio real.
# Ex: CORS_ORIGINS=https://centralops.exemplo.com
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Seguranca / Rate Limiting ────────────────────────────────────────────────
# AUTH_FAILURE_LIMIT=5
# AUTH_FAILURE_WINDOW_SECONDS=300
# AUTH_LOCKOUT_SECONDS=300
# RATE_LIMIT_PER_SECOND=10
# RATE_LIMIT_PER_MINUTE=100
# RATE_LIMIT_PER_HOUR=1000
# RATE_LIMIT_PER_DAY=50000

# ── Seguranca de rede — proxies confiaveis + egress allowlist ────────────────
# CIDRs de proxies confiaveis para honrar X-Forwarded-For (IP real do cliente).
# Em producao atras de ALB/Nginx/CloudFront, liste a rede do proxy. Vazio =
# ignora XFF e usa o IP da conexao direta. Aceita JSON ('["10.0.0.0/8"]') ou CSV.
# TRUSTED_PROXIES_CIDRS=10.0.0.0/8
#
# Allowlist de egress (SSRF hardening): hosts/CIDRs que o backend pode chamar
# em URLs de saida (ex: URL de Wazuh/integracoes). Match por sufixo de dominio
# (HOSTS) ou pelo IP resolvido (CIDRS). Vazio nos dois = sem restricao. CSV.
# OUTBOUND_URL_ALLOWED_HOSTS=
# OUTBOUND_URL_ALLOWED_CIDRS=

# ============================================================================
# Collector Multi-Tenant (Celery + Redis + Wazuh)
# ============================================================================
# Subsistema que coleta logs de APIs de terceiros (Sophos, Defender, NinjaOne)
# e envia ao Wazuh. Documentacao completa: docs/collector/README.md
# ============================================================================

# ── Redis (broker + cache + cursor + dedupe + domain semaphore) ──────────────
# Senha do Redis — OBRIGATORIA. Sem valor o compose recusa subir.
# Gere com: openssl rand -base64 24
REDIS_PASSWORD=
# REDIS_URL e inferido pelos servicos do compose; sobrescreva apenas se usar
# um Redis externo/managed.
# REDIS_URL=redis://:senha@redis:6379/0

# ── Celery (workers de coleta + Beat) ────────────────────────────────────────
# URLs sao derivadas de REDIS_URL por padrao (DB 1 = broker, DB 2 = backend).
# CELERY_BROKER_URL=redis://:senha@redis:6379/1
# CELERY_RESULT_BACKEND=redis://:senha@redis:6379/2

# Numero de replicas do worker de prioridade (EDR real-time).
COLLECTOR_PRIORITY_REPLICAS=2

# Numero de replicas do worker de dispatch (envia lotes ao Wazuh via Syslog/JSONL).
# W7: default 2 replicas x 8 threads = 16 workers concorrentes de dispatch.
# Escale em producao se a queue dispatch.wazuh acumular backlog.
COLLECTOR_DISPATCHER_REPLICAS=2

# HA do scheduler. 2 replicas de beat em hot-standby; o RedBeat
# elege o lider via lock distribuido (so 1 dispara). Ponha 1 so se quiser
# desligar a HA. REDBEAT_LOCK_TIMEOUT: TTL do lock (s); failover <= esse valor.
COLLECTOR_BEAT_REPLICAS=2
REDBEAT_LOCK_TIMEOUT=60

# teto de memoria da instancia de CACHE/DEDUPE. O broker + schedule vivem em
# OUTRA instancia (redis-control, com 'noeviction'); esta aqui usa
# 'volatile-lru', entao ao bater o teto ela EVICTA chaves de dedupe ANTES do TTL
# — e o evento volta a parecer inedito, sendo reentregue ao destino em silencio.
#
# DIMENSIONE PELO DEDUPE, que e o dominante:
#   chaves  ~= eventos_por_segundo x TTL_em_segundos
#   memoria ~= chaves x 115 bytes
# Ex.: 100 ev/s com TTL de 24h = ~8,6M chaves = ~1 GB (o dobro deste default).
# O mesmo volume com TTL de 4h = ~1,4M chaves = ~165 MB.
# O TTL e ajustavel na UI (/config -> Coleta & Entrega, em HORAS, minimo 4h).
# Ver docs-site/docs/runbooks/redis-capacity.md.
#
# Dimensione ABAIXO do limite de memoria do container do redis
# (default do compose: 768m).
REDIS_MAXMEMORY=512mb

# ── Destino no Wazuh / Collector / Dispatch ──────────────────────────────────
# Configurado na UI em /config → "Collector / Dispatch" (persistido na tabela
# ``collector_config`` + cache Redis 30s; a UI é a fonte da verdade no dia-a-dia).
# As env WAZUH_DISPATCH_MODE / WAZUH_SYSLOG_HOST / WAZUH_SYSLOG_PORT /
# WAZUH_CA_BUNDLE / COLLECTOR_JSONL_DIR ainda EXISTEM como SEED opcional do
# 1º boot (deploy headless/IaC sem acesso à UI): se setadas com a tabela vazia,
# materializam o destino ``wazuh-default``; se ausentes, o seed usa os defaults
# do app (mode=syslog, port=6514) e o operador configura pela UI. Removidas
# daqui para reduzir ruído — o caminho normal é a UI.

# ── Saida multi-destino ──────────────────────────────────────────
# Multi-destino e GA: a saida desacoplada (destinos + fan-out)
# e o comportamento PADRAO e incondicional. O roteamento por regra  tambem e SEMPRE-ATIVO (GA) — a antiga flag ``ROUTING_ENABLED`` foi
# REMOVIDA do codigo. O Wazuh (wazuh-default) mantem lane dedicada byte-a-byte;
# destinos/rotas habilitados recebem fan-out aditivo. Sem destinos extras nem
# rotas, o comportamento e identico ao historico (o lote inteiro vai ao
# wazuh-default). Gestao de destinos e rotas: UI em /destinations e /routes.

# Redacao de PII por rota. ON (default): rotas com
# pii_redaction mascaram/pseudonimizam/removem campos antes do destino daquela
# rota (mesma origem integra no lago, mascarada no SIEM). Sem NENHUMA rota com
# spec e byte-identico — o portao que importa e o POR-ROTA, a spec na rota ja e
# o sinal de habilitacao (mesma racional da ADR-0015 para as flags REDUCTION_*).
# FAIL-CLOSED: spec ruim e 422 no CRUD; rota com spec + flag OFF cai p/
# wazuh-default interno (nunca cleartext ao destino externo).
# PII_REDACTION_ENABLED=true

# ── Deteccao de campos novos (drift) ──────────────────
# O que gravar na coluna "Valor de amostra" do Drift Explorer:
#   masked (default) = so o FORMATO (<ipv4>, <email>, <string len=42>) — suficiente
#                      para escolher o campo OCSF de destino sem guardar dado do cliente;
#   raw              = o valor truncado (campo NAO mapeado e onde caem usuario, host,
#                      IP e linha de comando — use so com base legal para isso);
#   none             = nao guarda amostra nenhuma.
# A tabela e lida por perfil VIEWER e tem retencao de 90 dias.
# DRIFT_SAMPLE_VALUE_MODE=masked
# Fracao dos eventos inspecionada em regime (0 desliga):
# DRIFT_SAMPLE_RATE=0.1
# Primeiros N eventos de uma combinacao NOVA sao inspecionados a 100%:
# DRIFT_LEARNING_EVENTS=200

# ── Metering de custo/volume ──────────────────────────
# ON (default): mede eventos/bytes que entram/saem por org/source/destino
# (card de volume em /flow + GET /collectors/cost-summary) e e pre-requisito
# de TODA alavanca de reducao REDUCTION_* ("nao se reduz sem medir").
# Batched (1 flush Redis a cada ~500 eventos/15s) e fail-open — custo marginal
# no hot path. Opt-out (desliga tambem as REDUCTION_*):
# COST_METERING_ENABLED=false

# ── Observabilidade OTel: traces + metricas + LOGS ─────────
# Export vendor-neutro via OTLP p/ QUALQUER backend (Tempo/Jaeger/Datadog/
# Honeycomb/Grafana/Zabbix). Requer os pacotes opentelemetry-* (na imagem ou
# `pip install -r requirements-otel.txt`); ausentes => no-op total.
# Instrumentacao IN-CODE (app/collectors/{tracing,otel_metrics,otel_logs}.py,
# montados por filho prefork em worker_process_init) — NAO use o wrapper
# `opentelemetry-instrument`: o otel_logs.py ja anexa um LoggingHandler ao root
# logger, entao o logging nativo do Python exporta sozinho com os toggles abaixo
# ON (o wrapper DUPLICARIA os logs e exigiria pacotes extras).
#
# OTEL_ENABLED liga TRACES + METRICAS (OFF default = caminho byte-identico).
# OTEL_ENABLED=false
# OTEL_LOGS_ENABLED liga o sinal de LOGS (toggle SEPARADO — volume alto; requer
# OTEL_ENABLED=true tambem). E ESTE que faltava p/ os logs chegarem no Loki.
# OTEL_LOGS_ENABLED=false
# Nome do servico nos spans/resource (mesma identidade nos 3 sinais).
# OTEL_SERVICE_NAME=centralops-collector
# Endpoint OTLP/HTTP do Collector (base, sem /v1/...): o servico otel-collector
# escuta em :4318 na rede do compose. Vazio = usa os envs padrao do SDK.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# ── Dispatcher: runtime async persistente ────────────────
# Kill-switch do loop async long-lived do dispatcher. OFF (default): cada lote
# roda via asyncio.run (reconecta por lote — comportamento legado). ON ("1"):
# um event loop persistente por processo reusa UM socket TCP/TLS ao Wazuh
# (sem reconexao por lote). Rollback = "0" + restart do worker (sem redeploy).
# Ligue apos soak. Evidencia: scripts/bench_dispatch_socket_reuse.py.
# DISPATCH_PERSISTENT_LOOP=0
# Teto (s) do bloqueio cross-thread por lote. 600 < soft(720) < hard(900).
# DISPATCH_RESULT_TIMEOUT=600

# ── Quarentena: teto do raw_payload ARMAZENADO ───────────────────────────────
# Limite de bytes do raw_payload gravado em quarantine_events. NÃO é o caminho
# de saída ao Wazuh (esse não tem teto no CentralOps; o limite real downstream
# é o OS_MAXSTR=64KiB do Wazuh). Postgres Text/TOAST suporta ~1GB → este número
# é higiene de storage/UI. Acima dele, o writer PODA campos grandes mantendo
# JSON VÁLIDO + escalares de topo (inspeção e reprocesso parcial preservados).
# Mínimo 4096. Default 262144 (256 KiB).
# QUARANTINE_RAW_MAX_BYTES=262144

# ── Coleta: batch, dedupe, concorrencia e rate limits ────────────────────────
# Tambem gerenciados na UI em /config → "Collector / Dispatch" (tabela
# ``collector_config``). COLLECTOR_BATCH_SIZE/FLUSH, DEDUPE_TTL_DAYS,
# DOMAIN_CONCURRENCY_LIMITS e RATE_LIMITS_BY_VENDOR existem como SEED opcional
# do 1º boot; ausentes, o seed usa os defaults do app (batch=200, flush=5s,
# dedupe=7d, e os rate/concurrency por vendor de core/config.py). Ajuste fino
# (ex.: 429 em staging, tier pago do vendor) e feito na UI sem redeploy.

# ── Flower (UI de monitoramento das filas) ───────────────────────────────────
FLOWER_PORT=5555
# Em producao, SEMPRE configure basic auth (exemplo: user:senha).
# Gere: htpasswd -nbB admin "sua-senha"
# FLOWER_BASIC_AUTH=admin:senha

# ── Rollback de emergencia (NAO recomendado em producao) ─────────────────────
# Reativa o scheduler antigo em thread (services/scheduler.py). Desabilitado
# por padrao em favor do Celery Beat.
# ENABLE_LEGACY_THREAD_SCHEDULER=0

# ── Internal API (consumida pelo IASOC worker) ───────────────────────────────
# Shared secret aceito por /api/internal/* como FALLBACK do Bearer (PAT/SA
# token com scope ``internal.tenant.read``). Vazio = endpoint retorna 503,
# útil pra desligar a integração inteira sem mexer em código.
#
# Migração Fase 2: prefira Service Account + PAT em vez desta key. Ela é
# mantida durante 1 sprint pra coexistir com IASOC velho durante deploy
# desincronizado. Remova quando todos os IASOC estiverem em Bearer.
#
# Gere com: openssl rand -hex 32
# CENTRALOPS_INTERNAL_API_KEY=

# ── DFIR-IRIS (integracao OPCIONAL de IR) ─────────────────────────
# Integracao de BORDA opcional: o IRIS NAO participa da entrega de eventos (o
# envelope usa o Organization.id interno; o customer id externo vive em
# destination_customer_mappings, resolvido so na borda do connector). Vazio =
# desabilitado. Provisionamento via Sophos Partner sync (best-effort) ou endpoint
# /api/organizations/{id}/sync-iris-customer. Health: GET /api/iris/health.
# DFIR_IRIS_URL=https://iris.exemplo.com    # validado no boot (scheme http(s)+host)
# DFIR_IRIS_API_KEY=
# DFIR_IRIS_TLS_SKIP_VERIFY=false   # true só pra dev com cert self-signed
# 

# ── Sophos Partner Mode — schedule ──────────────────────────────────────────
# Cron expression do Celery Beat pra rodar sync_all_partners (descobre
# tenants novos/removidos em todos os Partner integrations ativos). Vazio
# desabilita o sync periódico — manual via POST /api/integrations/{id}/sync-tenants
# continua funcionando.
# Default: 04:00 UTC todo dia (formato 5-field "min hr dom mon dow").
# SOPHOS_PARTNER_SYNC_CRON=0 4 * * *

# ── Microsoft Entra ID — OIDC SSO ────────────────────────────────────────────
# "Entrar com Microsoft" (Authorization Code + PKCE). Configurado na UI em
# /config → "Identidade & SSO" (fonte da verdade = tabela `identity_config`,
# secret cifrado no banco). As env ENTRA_* abaixo são apenas SEED opcional do
# 1º boot (deploy headless); alterá-las após o seed não tem efeito. Guia:
# docs-site → Administração → SSO (Entra). Campos do seed: ENTRA_ENABLED,
# ENTRA_TENANT_ID, ENTRA_CLIENT_ID, ENTRA_CLIENT_SECRET, ENTRA_REDIRECT_URI,
# ENTRA_AUTHORITY, ENTRA_SCOPES, ENTRA_ROLE_MAP, ENTRA_DEFAULT_ROLE,
# ENTRA_DEFAULT_IS_GLOBAL, ENTRA_JIT_PROVISIONING, ENTRA_ALLOWED_EMAIL_DOMAINS,
# ENTRA_BUTTON_LABEL, ENTRA_POST_LOGIN_REDIRECT.
# ENTRA_SYNC_CRON: cron do Graph-sync de usuários (5 campos, vazio = off; mudar
# exige restart do Beat). O toggle de sync/deprovisionamento é gerido na UI.
# ENTRA_SYNC_CRON=

# ── Logging estruturado (Wazuh JSONL forwarding, RNF6.2) ─────────────────────
# Handler de arquivo JSONL com os logs DA APLICACAO (nao os eventos coletados),
# pra ser tail-ado pelo agente Wazuh. Rotation diaria, retencao 7 dias.
# LOGGING_WAZUH_JSONL_ENABLED=false
# LOGGING_WAZUH_JSONL_PATH=/var/log/centralops/app.jsonl

# ── Debug ────────────────────────────────────────────────────────────────────
DEBUG_REQUESTS=0
# ENABLE_API_DOCS=false
