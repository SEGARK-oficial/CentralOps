# ============================================================================
# CentralOps — compose/.env (exemplo)
# ============================================================================
# Copie para compose/.env e ajuste. O .env real é gitignored.
# cp compose/.env.example compose/.env
#
# Para produção basta ajustar estas variáveis.
# Referência completa de configuração: https://docs.segark.com/deployment/configuration
# ============================================================================

# ── Segredos obrigatórios ────────────────────────────────────────────────
# APP_MASTER_KEY: chave mestra de cifragem, MÍN. 32 chars. Gere:
# openssl rand -hex 32
APP_MASTER_KEY=troque-por-uma-chave-de-no-minimo-32-caracteres
# POSTGRES_PASSWORD: obrigatória (o compose recusa subir sem ela). Gere:
# openssl rand -base64 24
POSTGRES_PASSWORD=troque-me-postgres
# REDIS_PASSWORD: obrigatória (AUTH do Redis sempre habilitado). Gere:
# openssl rand -base64 24
REDIS_PASSWORD=troque-me-redis

# ── Imagens (build local vs. imagens prontas) ────────────────────────────
# Default: build local (image tag `centralops:latest`, compilada por `up --build`).
# Para RODAR AS IMAGENS PRONTAS do GHCR sem buildar, aponte IMAGE_NAME para o
# registry e fixe uma tag de release (o frontend recebe o sufixo `-frontend`):
#   IMAGE_NAME=ghcr.io/segark-oficial/centralops
#   IMAGE_TAG=v1.0.0
# Depois: docker compose -f compose/docker-compose.yml pull && ... up -d
# IMAGE_NAME=centralops
# IMAGE_TAG=latest

# ── Enterprise (overlay compose/docker-compose.ee.yml) ───────────────────
# A edição Enterprise sobe SEMPRE com os DOIS arquivos:
#   docker compose -f compose/docker-compose.yml -f compose/docker-compose.ee.yml up -d
# Dica (sticky overlay): descomente COMPOSE_FILE abaixo e rode `docker compose`
# de dentro de compose/ — o `up -d` já aplica a overlay e os comandos day-2
# (stop/restart/logs/ps) não rebaixam a stack para Community por esquecer um -f.
# COMPOSE_FILE=docker-compose.yml:docker-compose.ee.yml
#
# LICENSE_KEYS_DIR: OBRIGATÓRIA com a overlay (o compose recusa subir sem ela).
# Diretório no HOST com a(s) chave(s) pública(s) da licença (<kid>.pem, ex.:
# key.prod.pem). Caminho relativo resolve contra o diretório do PRIMEIRO -f
# (compose/), não o cwd do shell. O .pem precisa ser legível pelo uid 10001 do
# container: chmod 0644 no arquivo e 0755 no diretório.
# LICENSE_KEYS_DIR=./license-keys
#
# CENTRALOPS_LICENSE_TOKEN: token de licença (JWT EdDSA). OPCIONAL aqui — a
# alternativa é colar o token na UI (Configurações → Licença), que ativa SEM
# reiniciar nada (o keyring é relido a cada ativação). Nunca commite o token.
# CENTRALOPS_LICENSE_TOKEN=
#
# Imagens Enterprise publicadas (fixe uma tag de release):
# CENTRALOPS_EE_IMAGE=ghcr.io/segark-oficial/centralops-ee:v1.0.1-ee
# CENTRALOPS_WEB_EE_IMAGE=ghcr.io/segark-oficial/centralops-ee-frontend:v1.0.1-ee

# ── Ambiente ─────────────────────────────────────────────────────────────
# production força SESSION_SECURE_COOKIE=true (TLS na borda). Use development
# só p/ rodar em HTTP puro local.
APP_ENV=production

# ── Frontend / TLS (serviço `frontend`) ──────────────────────────────────
# Portas publicadas no host pelo nginx do frontend. Aponte o domínio/reverse-proxy
# para o serviço `frontend` (não o `centralops`).
HTTP_PORT=3000
HTTPS_PORT=3443
# 1 = TLS na borda (prod). 0 = HTTP puro (dev; combine com SESSION_SECURE_COOKIE=0).
ENABLE_HTTPS=1
# NGINX_SERVER_NAME=centralops.exemplo.com

# ── Data-plane (Kafka / Redpanda) ────────────────────────────────────────
# Transporte durável dos eventos entre coleta e entrega. Mantenha kafka.
EVENT_DATAPLANE=kafka
# Self-host single-node: o serviço `redpanda` do compose. PROD: aponte para um
# broker gerenciado (MSK / Redpanda Cloud / Confluent) e NÃO suba o redpanda local.
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
# Isola ambientes que compartilham um cluster (ex.: centralops-staging).
# KAFKA_TOPIC_PREFIX=centralops
# KAFKA_DELIVER_TOPIC=deliver
# KAFKA_DELIVER_PARTITIONS=8
# Fator de replicação do tópico: 1 self-host single-node; 3 em prod HA.
KAFKA_DELIVER_REPLICATION=1
# Consumer group do dispatcher (mude apenas se o cluster for compartilhado).
# KAFKA_CONSUMER_GROUP=centralops-dispatcher
# KAFKA_MAX_REQUEST_BYTES=8388608
#
# Segurança em broker gerenciado: PLAINTEXT (self-host) | SASL_PLAINTEXT | SASL_SSL.
# Com SASL_*, defina também KAFKA_SASL_MECHANISM (o serviço não sobe sem ele).
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_MECHANISM=SCRAM-SHA-512   # PLAIN | SCRAM-SHA-256 | SCRAM-SHA-512
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=
#
# Resiliência (defaults sãos; descomente só p/ tuning):
# KAFKA_MAX_DELIVERY_ATTEMPTS=10       # retentativas transitórias antes da DLQ
# KAFKA_REQUEST_TIMEOUT_MS=10000
# KAFKA_PRODUCE_WAIT_S=12              # deve ser > KAFKA_REQUEST_TIMEOUT_MS (em s)
# KAFKA_MAX_POLL_INTERVAL_MS=900000
# KAFKA_LAG_REFRESH_SECONDS=15
# Réplicas do consumer Kafka (data-plane).
# COLLECTOR_KAFKA_DISPATCHER_REPLICAS=2

# ── Observabilidade (OpenTelemetry) ──────────────────────────────────────
# Export OTLP vendor-neutro p/ QUALQUER backend (Tempo/Jaeger/Datadog/Grafana...).
# OTEL_ENABLED liga traces + métricas; OTEL_LOGS_ENABLED é separado e EXIGE
# OTEL_ENABLED=true.
OTEL_ENABLED=false
# OTEL_LOGS_ENABLED=false
# Endpoint OTLP/HTTP base (sem /v1/...). Vazio = usa os envs padrão do SDK.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_METRIC_EXPORT_INTERVAL_MS=60000
# Amostragem de traces, de 0.0 a 1.0 (valores fora da faixa impedem a subida).
# OTEL_TRACES_SAMPLER_RATIO=1.0

# ── Escala (compose: deploy.replicas; honrado por Swarm/k8s/--scale) ──────
# COLLECTOR_PRIORITY_REPLICAS=2
# COLLECTOR_DISPATCHER_REPLICAS=2
# beat é scheduler singleton; default 1. Rodar 2+ é SEGURO (lock RedBeat), mas
# só via Swarm/k8s/`--scale` (compose puro ignora replicas). O 2º beat é standby.
# COLLECTOR_BEAT_REPLICAS=1

# ── Redis ────────────────────────────────────────────────────────────────
# Dois papéis SEPARADOS (a política de eviction é GLOBAL por instância):
#   redis          → cache/dedup (db0), maxmemory-policy=volatile-lru
#   redis-control  → broker + schedule/lock RedBeat + result, policy=noeviction
# (o lock do RedBeat TEM TTL → sob volatile-lru seria evictável → crash-loop do
#  beat; por isso o control-plane fica isolado em noeviction).
# REDIS_MAXMEMORY=512mb           # instância de cache/dedup
# REDIS_CONTROL_MAXMEMORY=256mb   # instância de control-plane (dataset pequeno)

# ── Flower (UI das filas Celery) ─────────────────────────────────────────
# Em produção SEMPRE configure basic auth (obrigatório quando APP_ENV=production):
# htpasswd -nbB admin "sua-senha"
# FLOWER_BASIC_AUTH=admin:senha
