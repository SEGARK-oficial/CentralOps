      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (destination_id, outcome) (rate(collector_dataplane_produced_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{destination_id}} · {{outcome}}"
        }
      ],
      "title": "Produce rate (por destino / outcome)",
      "type": "timeseries",
      "transparent": true
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "gradientMode": "opacity",
