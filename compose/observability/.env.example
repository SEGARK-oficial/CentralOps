# Stack de observabilidade CentralOps (.108) — copie para .env e ajuste.

# Senha admin da Grafana.
GRAFANA_ADMIN_PASSWORD=troque-me

# Token compartilhado Grafana <-> image-renderer (qualquer string longa aleatória;
# o MESMO valor nos dois serviços).
RENDERER_TOKEN=troque-por-uma-string-longa-aleatoria
