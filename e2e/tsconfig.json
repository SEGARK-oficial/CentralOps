{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": ".tsc-out",
    "baseUrl": "."
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", ".tsc-out"]
}
