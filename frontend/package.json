{
  "name": "sophos-gui-refactored",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "i18n:check": "node scripts/check-i18n.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "e2e": "npm --prefix ../e2e run test",
    "e2e:headed": "npm --prefix ../e2e run test:headed",
    "e2e:report": "npm --prefix ../e2e run report",
    "e2e:up": "docker compose -f ../compose/docker-compose.e2e.yml up --build -d",
    "e2e:down": "docker compose -f ../compose/docker-compose.e2e.yml down -v"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-focus-scope": "^1.1.8",
    "@radix-ui/react-slot": "^1.0.2",
    "@tanstack/react-virtual": "^3.13.24",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.6.0",
    "react-json-view-lite": "^2.5.0",
    "react-resizable-panels": "^2.1.9",
    "react-router-dom": "^6.30.2",
    "tailwind-merge": "^3.5.0",
    "vite-plugin-svgr": "^5.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^8.53.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.2.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
