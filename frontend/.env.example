# URL do backend para o dev server do Vite (sem Docker). Em produção o build
# via compose injeta VITE_BACKEND_URL=/api como build-arg — não use este arquivo.
VITE_BACKEND_URL=http://localhost:8000/api

# Branding (nome da empresa / portal) NÃO vem mais do .env do frontend: a UI
# busca via GET /api/auth/status, que lê APP_COMPANY_NAME / APP_COMPANY_PORTAL_NAME
# do backend (.env raiz). As antigas VITE_COMPANY_NAME / VITE_COMPANY_PORTAL_NAME
# eram ignoradas no build e foram removidas.
