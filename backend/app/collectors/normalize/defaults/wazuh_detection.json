{
  "rules": [
    {
      "target": "normalized.class_uid",
      "const": 2004,
      "required": true
    },
    {
      "target": "normalized.class_name",
      "const": "Detection Finding"
    },
    {
      "target": "normalized.category_uid",
      "const": 2,
      "required": true
    },
    {
      "target": "normalized.category_name",
      "const": "Findings"
    },
    {
      "target": "normalized.activity_id",
      "const": 1
    },
    {
      "target": "normalized.activity_name",
      "const": "Create"
    },
    {
      "target": "normalized.type_uid",
      "const": 200401
    },
    {
      "target": "normalized.time",
      "source": "timestamp || \"@timestamp\"",
      "type_cast": "iso_to_epoch",
      "required": true
    },
    {
      "target": "normalized.finding_info.uid",
      "source": "id",
      "required": true
    },
    {
      "target": "normalized.finding_info.title",
      "source": "rule.description",
      "default": null
    },
    {
      "target": "normalized.finding_info.created_time",
      "source": "timestamp || \"@timestamp\"",
      "type_cast": "iso_to_epoch"
    },
    {
      "target": "normalized.finding_info.types",
      "source": "rule.groups",
      "default": []
    },
    {
      "target": "normalized.finding_info.analytic.type_id",
      "const": 1
    },
    {
      "target": "normalized.finding_info.analytic.type",
      "const": "Rule"
    },
    {
      "target": "normalized.finding_info.analytic.uid",
      "source": "rule.id",
      "default": null
    },
    {
      "target": "normalized.finding_info.analytic.name",
      "source": "rule.description",
      "default": null
    },
    {
      "target": "normalized.severity_id",
      "source": "rule.level",
      "pre_cast": "to_str",
      "value_map": {
        "0": 1,
        "1": 1,
        "2": 1,
        "3": 1,
        "4": 2,
        "5": 2,
        "6": 2,
        "7": 3,
        "8": 3,
        "9": 3,
        "10": 3,
        "11": 3,
        "12": 4,
        "13": 4,
        "14": 4,
        "15": 5,
        "16": 5
      },
      "default": 1,
      "required": true
    },
    {
      "target": "normalized.severity",
      "source": "rule.level",
      "pre_cast": "to_str",
      "value_map": {
        "0": "Informational",
        "1": "Informational",
        "2": "Informational",
        "3": "Informational",
        "4": "Low",
        "5": "Low",
        "6": "Low",
        "7": "Medium",
        "8": "Medium",
        "9": "Medium",
        "10": "Medium",
        "11": "Medium",
        "12": "High",
        "13": "High",
        "14": "High",
        "15": "Critical",
        "16": "Critical"
      },
      "default": "Unknown"
    },
    {
      "target": "normalized.status_id",
      "const": 1
    },
    {
      "target": "normalized.status",
      "const": "New"
    },
    {
      "target": "normalized.message",
      "source": "rule.description || full_log",
      "default": null
    },
    {
      "target": "normalized.device.name",
      "source": "agent.name",
      "default": null
    },
    {
      "target": "normalized.device.hostname",
      "source": "agent.name",
      "default": null
    },
    {
      "target": "normalized.device.uid",
      "source": "agent.id",
      "default": null
    },
    {
      "target": "normalized.device.ip",
      "source": "agent.ip",
      "default": null
    },
    {
      "target": "normalized.actor.user.name",
      "source": "data.srcuser || data.dstuser || data.user",
      "default": null
    },
    {
      "target": "normalized.metadata.version",
      "const": "1.8.0"
    },
    {
      "target": "normalized.metadata.product.name",
      "const": "Wazuh"
    },
    {
      "target": "normalized.metadata.product.vendor_name",
      "const": "Wazuh"
    },
    {
      "target": "normalized.metadata.uid",
      "source": "id"
    },
    {
      "target": "normalized.metadata.event_code",
      "source": "rule.id",
      "default": null
    },
    {
      "target": "normalized.metadata.log_name",
      "source": "location",
      "default": null
    },
    {
      "target": "normalized.unmapped.rule.groups",
      "source": "rule.groups",
      "default": []
    },
    {
      "target": "normalized.unmapped.rule.firedtimes",
      "source": "rule.firedtimes",
      "default": null
    },
    {
      "target": "normalized.unmapped.rule.pci_dss",
      "source": "rule.pci_dss",
      "default": null
    },
    {
      "target": "normalized.unmapped.rule.hipaa",
      "source": "rule.hipaa",
      "default": null
    },
    {
      "target": "normalized.unmapped.rule.nist_800_53",
      "source": "rule.nist_800_53",
      "default": null
    },
    {
      "target": "normalized.unmapped.rule.gdpr",
      "source": "rule.gdpr",
      "default": null
    },
    {
      "target": "normalized.unmapped.rule.tsc",
      "source": "rule.tsc",
      "default": null
    },
    {
      "target": "normalized.unmapped.rule.mitre",
      "source": "rule.mitre",
      "default": null
    },
    {
      "target": "normalized.unmapped.data",
      "source": "data",
      "default": null
    },
    {
      "target": "normalized.unmapped.full_log",
      "source": "full_log",
      "default": null
    },
    {
      "target": "normalized.unmapped.predecoder.hostname",
      "source": "predecoder.hostname",
      "default": null
    },
    {
      "target": "normalized.unmapped.decoder",
      "source": "decoder.name",
      "default": null
    },
    {
      "target": "normalized.unmapped.manager",
      "source": "manager.name",
      "default": null
    },
    {
      "target": "normalized.unmapped.location",
      "source": "location",
      "default": null
    },
    {
      "target": "normalized.observables",
      "kind": "array_builder",
      "items": [
        {
          "name": "device_name",
          "type": "Hostname",
          "type_id": 1,
          "source": "agent.name",
          "skip_null": true
        },
        {
          "name": "device_uid",
          "type": "Resource UID",
          "type_id": 33,
          "source": "agent.id",
          "skip_null": true
        },
        {
          "name": "src_ip",
          "type": "IP Address",
          "type_id": 2,
          "source": "data.srcip",
          "skip_null": true
        },
        {
          "name": "dst_ip",
          "type": "IP Address",
          "type_id": 2,
          "source": "data.dstip",
          "skip_null": true
        },
        {
          "name": "src_mac",
          "type": "MAC Address",
          "type_id": 3,
          "source": "data.srcmac",
          "skip_null": true
        }
      ],
      "skip_null": true,
      "dedup_by": [
        "value"
      ]
    }
  ],
  "raw_reduction": [
    {
      "path": "full_log",
      "max_bytes": 16384
    },
    {
      "path": "data.win.system.message",
      "max_bytes": 8192
    }
  ]
}