{
  "rules": [
    { "target": "normalized.class_uid", "const": 2004, "required": true },
    { "target": "normalized.class_name", "const": "Detection Finding" },
    { "target": "normalized.category_uid", "const": 2, "required": true },
    { "target": "normalized.category_name", "const": "Findings" },
    { "target": "normalized.activity_id", "const": 1 },
    { "target": "normalized.activity_name", "const": "Create" },
    { "target": "normalized.type_uid", "const": 200401 },

    { "target": "normalized.time", "source": "created_timestamp", "type_cast": "iso_to_epoch", "required": true },

    { "target": "normalized.finding_info.uid", "source": "composite_id || id", "required": true },
    { "target": "normalized.finding_info.title", "source": "display_name || name || description", "default": null },
    { "target": "normalized.finding_info.created_time", "source": "created_timestamp", "type_cast": "iso_to_epoch" },
    { "target": "normalized.finding_info.types", "source": "[tactic]", "default": [] },

    {
      "target": "normalized.severity_id",
      "source": "severity_name",
      "value_map": {
        "Informational": 1, "informational": 1,
        "Low": 2, "low": 2,
        "Medium": 3, "medium": 3,
        "High": 4, "high": 4,
        "Critical": 5, "critical": 5
      },
      "default": 0,
      "required": true
    },
    { "target": "normalized.severity", "source": "severity_name", "default": "Unknown" },

    {
      "target": "normalized.status_id",
      "source": "status",
      "value_map": { "new": 1, "New": 1, "in_progress": 2, "reopened": 1, "closed": 4 },
      "default": 0
    },
    { "target": "normalized.status", "source": "status", "default": null },

    { "target": "normalized.message", "source": "description || display_name", "default": null },

    { "target": "normalized.device.name", "source": "device.hostname", "default": null },
    { "target": "normalized.device.hostname", "source": "device.hostname", "default": null },
    { "target": "normalized.device.uid", "source": "device.device_id || device.id", "default": null },
    { "target": "normalized.device.ip", "source": "device.local_ip", "default": null },
    { "target": "normalized.device.os.name", "source": "device.platform_name", "default": null },

    { "target": "normalized.actor.user.name", "source": "user_name", "default": null },

    { "target": "normalized.metadata.version", "const": "1.8.0" },
    { "target": "normalized.metadata.product.name", "const": "Falcon" },
    { "target": "normalized.metadata.product.vendor_name", "const": "CrowdStrike" },
    { "target": "normalized.metadata.uid", "source": "composite_id || id" },

    {
      "target": "normalized.observables",
      "kind": "array_builder",
      "items": [
        { "name": "device_name", "type": "Hostname", "type_id": 1, "source": "device.hostname", "skip_null": true },
        { "name": "device_uid", "type": "Resource UID", "type_id": 33, "source": "device.device_id", "skip_null": true },
        { "name": "local_ip", "type": "IP Address", "type_id": 2, "source": "device.local_ip", "skip_null": true },
        { "name": "external_ip", "type": "IP Address", "type_id": 2, "source": "device.external_ip", "skip_null": true },
        { "name": "file_hash", "type": "Hash", "type_id": 8, "source": "sha256", "skip_null": true },
        { "name": "file_name", "type": "File Name", "type_id": 7, "source": "filename", "skip_null": true }
      ],
      "skip_null": true,
      "dedup_by": ["value"]
    }
  ]
}
