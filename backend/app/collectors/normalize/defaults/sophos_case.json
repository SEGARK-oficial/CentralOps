{
  "rules": [
    { "target": "normalized.class_uid", "const": 2005, "required": true },
    { "target": "normalized.class_name", "const": "Incident Finding" },
    { "target": "normalized.category_uid", "const": 2, "required": true },
    { "target": "normalized.category_name", "const": "Findings" },
    { "target": "normalized.activity_id", "const": 1 },
    { "target": "normalized.activity_name", "const": "Create" },
    { "target": "normalized.type_uid", "const": 200501 },
    { "target": "normalized.time", "source": "createdAt", "type_cast": "iso_to_epoch", "required": true },

    { "target": "normalized.finding_info.uid", "source": "id", "required": true },
    { "target": "normalized.finding_info.title", "source": "name", "default": null },
    { "target": "normalized.finding_info.desc", "source": "description", "default": null },
    { "target": "normalized.finding_info.created_time", "source": "createdAt", "type_cast": "iso_to_epoch" },
    { "target": "normalized.finding_info.modified_time", "source": "updatedAt", "type_cast": "iso_to_epoch", "default": null },

    {
      "target": "normalized.severity_id",
      "source": "severity",
      "value_map": {
        "critical": 5, "high": 4, "medium": 3, "low": 2, "info": 1, "informational": 1
      },
      "default": 0,
      "required": true
    },
    { "target": "normalized.severity", "source": "severity", "default": "Unknown" },

    {
      "target": "normalized.status_id",
      "source": "status",
      "value_map": {
        "new": 1, "open": 1, "investigating": 2, "in_progress": 2,
        "closed": 4, "resolved": 4, "suppressed": 3
      },
      "default": 0
    },
    { "target": "normalized.status", "source": "status", "default": "Unknown" },

    { "target": "normalized.assignee.name", "source": "assignee.name", "default": null },
    { "target": "normalized.assignee.uid", "source": "assignee.id", "default": null },

    { "target": "normalized.metadata.version", "const": "1.3.0" },
    { "target": "normalized.metadata.product.name", "const": "Sophos Central" },
    { "target": "normalized.metadata.product.vendor_name", "const": "Sophos" },
    { "target": "normalized.metadata.product.feature.name", "const": "MDR/XDR Cases" },
    { "target": "normalized.metadata.uid", "source": "id" },

    {
      "target": "normalized.observables",
      "kind": "array_builder",
      "items": [
        {
          "name": "tenant_id",
          "type": "Resource UID",
          "type_id": 33,
          "source": "tenant.id",
          "skip_null": true
        },
        {
          "name": "case_id",
          "type": "Other UID",
          "type_id": 34,
          "source": "id",
          "skip_null": true
        }
      ],
      "skip_null": true,
      "dedup_by": ["value"]
    }
  ]
}
