{
  "rules": [
    {
      "target": "normalized.class_uid",
      "const": 3002,
      "required": true
    },
    {
      "target": "normalized.class_name",
      "const": "Authentication"
    },
    {
      "target": "normalized.category_uid",
      "const": 3,
      "required": true
    },
    {
      "target": "normalized.category_name",
      "const": "Identity & Access Management"
    },
    {
      "target": "normalized.activity_id",
      "const": 1
    },
    {
      "target": "normalized.activity_name",
      "const": "Logon"
    },
    {
      "target": "normalized.type_uid",
      "const": 300201
    },
    {
      "target": "normalized.time",
      "source": "createdDateTime",
      "type_cast": "iso_to_epoch",
      "required": true
    },
    {
      "target": "normalized.severity_id",
      "const": 1,
      "required": true
    },
    {
      "target": "normalized.severity",
      "const": "Informational"
    },
    {
      "target": "normalized.status",
      "source": "status.failureReason",
      "default": null
    },
    {
      "target": "normalized.message",
      "source": "appDisplayName",
      "default": null
    },
    {
      "target": "normalized.user.name",
      "source": "userPrincipalName",
      "default": null
    },
    {
      "target": "normalized.user.uid",
      "source": "userId",
      "default": null
    },
    {
      "target": "normalized.user.full_name",
      "source": "userDisplayName",
      "default": null
    },
    {
      "target": "normalized.src_endpoint.ip",
      "source": "ipAddress",
      "default": null
    },
    {
      "target": "normalized.device.os.name",
      "source": "deviceDetail.operatingSystem",
      "default": null
    },
    {
      "target": "normalized.metadata.version",
      "const": "1.8.0"
    },
    {
      "target": "normalized.metadata.product.name",
      "const": "Microsoft Entra ID"
    },
    {
      "target": "normalized.metadata.product.vendor_name",
      "const": "Microsoft"
    },
    {
      "target": "normalized.metadata.uid",
      "source": "id"
    },
    {
      "target": "normalized.observables",
      "kind": "array_builder",
      "items": [
        {
          "name": "user",
          "type": "User Name",
          "type_id": 4,
          "source": "userPrincipalName",
          "skip_null": true
        },
        {
          "name": "src_ip",
          "type": "IP Address",
          "type_id": 2,
          "source": "ipAddress",
          "skip_null": true
        }
      ],
      "skip_null": true,
      "dedup_by": [
        "value"
      ]
    }
  ],
  "raw_reduction": [
    {
      "drop_nulls": true
    }
  ]
}
