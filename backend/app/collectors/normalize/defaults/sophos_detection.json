{
  "preprocess": [
    {
      "op": "json_parse",
      "source": "processedData",
      "target": "_processed",
      "tolerant": true
    },
    {
      "op": "json_parse",
      "source": "rawData.raw",
      "target": "_raw_email",
      "tolerant": true
    }
  ],
  "rules": [
    { "target": "normalized.class_uid", "const": 2004, "required": true },
    { "target": "normalized.class_name", "const": "Detection Finding" },
    { "target": "normalized.category_uid", "const": 2, "required": true },
    { "target": "normalized.category_name", "const": "Findings" },
    { "target": "normalized.activity_id", "const": 1 },
    { "target": "normalized.activity_name", "const": "Create" },
    { "target": "normalized.type_uid", "const": 200401 },

    { "target": "normalized.time", "source": "time", "fallback_source": ["sensorGeneratedAt"], "default_from": "ingest_time", "type_cast": "iso_to_epoch", "required": true },
    { "target": "normalized.finding_info.uid", "source": "id", "required": true },
    {
      "target": "normalized.finding_info.title",
      "source": "detectionRule",
      "fallback_source": ["attackType"],
      "default": null
    },
    { "target": "normalized.finding_info.types", "source": "[type]", "default": [] },
    { "target": "normalized.finding_info.created_time", "source": "time", "fallback_source": ["sensorGeneratedAt"], "type_cast": "iso_to_epoch" },

    {
      "target": "normalized.severity_id",
      "source": "severity",
      "type_cast": "to_int",
      "default": 0,
      "required": true
    },
    { "target": "normalized.severity", "source": "severity", "type_cast": "to_str", "default": "Unknown" },

    { "target": "normalized.status_id", "const": 1 },
    { "target": "normalized.status", "const": "New" },

    { "target": "normalized.message", "source": "detectionRule", "default": null },

    { "target": "normalized.device.name", "source": "device.entity", "default": null },
    { "target": "normalized.device.uid", "source": "device.id", "default": null },
    { "target": "normalized.device.type", "source": "device.type", "default": null },

    { "target": "normalized.attacks", "source": "mitreAttacks", "default": [] },

    { "target": "normalized.metadata.version", "const": "1.3.0" },
    { "target": "normalized.metadata.product.name", "const": "Sophos Central" },
    { "target": "normalized.metadata.product.vendor_name", "const": "Sophos" },
    { "target": "normalized.metadata.product.feature.name", "const": "XDR Detections" },
    { "target": "normalized.metadata.uid", "source": "id" },

    {
      "target": "normalized.observables",
      "kind": "array_builder",
      "items": [
        {
          "name": "src_ip",
          "type": "IP Address",
          "type_id": 2,
          "source": "_processed.parsedAlert.fields.clientIp",
          "skip_null": true
        },
        {
          "name": "email_from",
          "type": "Email Address",
          "type_id": 5,
          "source": "_processed.parsedAlert.fields.mailFrom",
          "skip_null": true
        },
        {
          "name": "email_to",
          "type": "Email Address",
          "type_id": 5,
          "source": "_processed.parsedAlert.fields.envelopeRecipients",
          "explode": true,
          "skip_null": true
        },
        {
          "name": "file_hash",
          "type": "Hash",
          "type_id": 8,
          "source": "_processed.parsedAlert.fields.attachments[*].checksum",
          "explode": true,
          "skip_null": true
        },
        {
          "name": "file_name",
          "type": "File Name",
          "type_id": 7,
          "source": "_processed.parsedAlert.fields.attachments[*].name",
          "explode": true,
          "skip_null": true
        }
      ],
      "skip_null": true,
      "dedup_by": ["value"]
    }
  ],
  "raw_reduction": [
    { "path": "processedData", "max_bytes": 16384 },
    { "path": "rawData.raw", "max_bytes": 16384 }
  ]
}
